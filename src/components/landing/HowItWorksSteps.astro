---
import Container from '../ui/Container.astro';

const steps = [
  { num: '1', title: 'Konzultace', desc: 'pochopíme váš cíl' },
  { num: '2', title: 'Tvorba webu', desc: 'přizpůsobíme obsah i strukturu' },
  { num: '3', title: 'Předání', desc: 'web je váš, běží pod vaší doménou' },
  { num: '4', title: 'Buďte vidět', desc: 'nabízíme navazující SEO a reklamu' },
];
---

<section id="jak-funguje" class="py-12 md:py-16 bg-neutral-50 scroll-mt-20">
  <Container>
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-2 text-center">Jak funguje prodej webu</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-10">
        {steps.map((step) => (
          <div class="bg-white rounded-2xl p-6 shadow-md border-2 border-neutral-100 text-center hover:border-[#fdc700]/40 transition-colors">
            <div class="w-14 h-14 bg-[#fdc700] text-neutral-900 rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
              {step.num}
            </div>
            <h3 class="text-lg font-bold mb-2 text-neutral-800">{step.title}</h3>
            <p class="text-neutral-600 text-sm">{step.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-xl font-semibold text-neutral-700 mt-10">Jednoduché. Přehledné. Férové.</p>
    </div>
  </Container>
</section>
