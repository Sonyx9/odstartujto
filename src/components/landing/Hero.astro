---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden bg-neutral-50">
  <div class="pt-16 md:pt-24 pb-16 md:pb-20">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-800 mb-0">
          <span>Web, který přivádí zákazníky.</span><br />
          <span class="font-normal">Ne design award.</span> <span class="relative inline-block"><span class="relative z-10">Výsledky.</span><svg class="absolute left-0 -bottom-1 md:-bottom-1.5 w-full h-2 md:h-3 text-[#fdc700]" viewBox="0 0 120 12" preserveAspectRatio="none"><path d="M 0 2 Q 60 10 120 2" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></span>
        </h1>
        <p class="text-xl md:text-2xl font-semibold text-neutral-700 my-6">Statický web spustíme za pár dnů. Bez čekání, bez přemrštěných cen.</p>
        <p class="text-lg md:text-xl text-neutral-600 mb-10">
          Za 10+ let jsme budovali weby pro firmy různých velikostí. Dnes nás nejvíc baví pomáhat podnikatelům, kteří chtějí jednoduché řešení – web, který funguje, a marketing, který přivádí poptávky.
        </p>

        <!-- Dekorace -->
        <div class="flex items-center justify-center gap-2 mb-8">
          <span class="w-6 md:w-8 h-1 rounded-full bg-[#fdc700]" />
          <span class="w-2.5 h-2.5 rounded-full bg-[#fdc700] shadow-[0_0_8px_rgba(253,199,0,0.5)]" />
          <span class="w-6 md:w-8 h-1 rounded-full bg-[#fdc700]" />
        </div>

        <Button href="#poptavka" variant="primary" class="text-lg px-8 py-4 rounded-2xl hover:bg-[#fdc700] hover:text-neutral-800">
          Chci nezávaznou nabídku
        </Button>
        <p class="text-sm text-neutral-500 mt-3">Bez závazků. Odpovídáme do 24 hodin.</p>

        <!-- Social proof mini -->
        <div class="mt-10 flex justify-center items-center gap-4 flex-wrap">
          <div class="flex items-center gap-2 text-sm text-neutral-600">
            <svg class="w-5 h-5 text-[#fdc700]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span><strong>50+</strong> spokojených klientů</span>
          </div>
          <span class="text-neutral-300">|</span>
          <div class="flex items-center gap-2 text-sm text-neutral-600">
            <svg class="w-5 h-5 text-[#fdc700]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Web za <strong>pár dnů</strong></span>
          </div>
          <span class="text-neutral-300">|</span>
          <div class="flex items-center gap-2 text-sm text-neutral-600">
            <svg class="w-5 h-5 text-[#fdc700]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span><strong>10+ let</strong> zkušeností</span>
          </div>
        </div>

        <!-- Ceny -->
        <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <div class="py-8 px-6 bg-white rounded-2xl shadow-md border-2 border-[#fdc700] text-center">
            <p class="text-neutral-600 font-semibold text-sm mb-1">Statický web od</p>
            <p class="text-4xl md:text-5xl font-bold text-neutral-800">9 400 Kč</p>
            <p class="text-neutral-600 text-xs md:text-sm mt-2">jednorázově, včetně hostingu a správy</p>
          </div>
          <div class="py-8 px-6 bg-white rounded-2xl shadow-md border-2 border-neutral-200 text-center hover:border-[#fdc700] transition-colors">
            <p class="text-neutral-600 font-semibold text-sm mb-1">Marketing od</p>
            <p class="text-4xl md:text-5xl font-bold text-neutral-800">1 970 Kč <span class="text-lg font-semibold text-neutral-600">/měsíc</span></p>
            <p class="text-neutral-600 text-xs md:text-sm mt-2">Google Ads (volitelně)</p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Yellow separator -->
  <div class="h-1 bg-[#fdc700] w-full" />
</section>
