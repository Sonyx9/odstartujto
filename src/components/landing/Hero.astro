---
import Container from '../ui/Container.astro';
---

<section class="relative overflow-hidden bg-white">

  <!-- Dekorativní blob vlevo nahoře -->
  <div class="pointer-events-none absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-[#fdc700]/10 blur-3xl" aria-hidden="true"></div>
  <!-- Dekorativní blob vpravo dole -->
  <div class="pointer-events-none absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-[#292e4c]/5 blur-3xl" aria-hidden="true"></div>

  <Container>
    <div class="relative pt-14 md:pt-20 pb-16 md:pb-24 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- ── LEVÝ SLOUPEC: Text ── -->
      <div class="flex flex-col items-start">

        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold text-neutral-900 leading-tight mb-5">
          Web, který<br />
          přivádí zákazníky.<br />
          <span class="relative inline-block mt-1">
            <span class="relative z-10 text-[#292e4c]">Ne design award.</span>
            <svg class="absolute left-0 -bottom-1 w-full h-3 text-[#fdc700]" viewBox="0 0 300 12" preserveAspectRatio="none">
              <path d="M 0 8 Q 150 0 300 8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </h1>

        <!-- Perex -->
        <p class="text-lg text-neutral-600 mb-8 leading-relaxed max-w-md">
          Statický web od <strong class="text-neutral-800">9 400 Kč</strong>, spuštění do <strong class="text-neutral-800">5 dnů</strong>. Hosting a správa jen <strong class="text-neutral-800">2 890 Kč/rok</strong>. Lukáš a Standa, 10+ let v oboru.
        </p>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 mb-8">
          <a href="#poptavka" class="group inline-flex items-center gap-2 bg-[#fdc700] hover:bg-[#292e4c] text-neutral-900 hover:text-white font-bold text-base px-7 py-3.5 rounded-2xl transition-all duration-200 shadow-lg hover:shadow-xl">
            Chci nezávaznou nabídku
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <span class="text-sm text-neutral-500">Bez závazků · Odpovídáme do 24 h</span>
        </div>

        <!-- Social proof avatary -->
        <div class="flex items-center gap-3">
          <div class="flex -space-x-2.5">
            <div class="w-9 h-9 rounded-full bg-[#292e4c] border-2 border-white flex items-center justify-center text-white text-xs font-bold">M</div>
            <div class="w-9 h-9 rounded-full bg-[#fdc700] border-2 border-white flex items-center justify-center text-neutral-900 text-xs font-bold">J</div>
            <div class="w-9 h-9 rounded-full bg-neutral-400 border-2 border-white flex items-center justify-center text-white text-xs font-bold">T</div>
            <div class="w-9 h-9 rounded-full bg-[#292e4c]/70 border-2 border-white flex items-center justify-center text-white text-xs font-bold">+</div>
          </div>
          <div>
            <div class="flex items-center gap-1">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-[#fdc700]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-xs text-neutral-600 mt-0.5"><strong class="text-neutral-800">50+</strong> spokojených klientů</p>
          </div>
        </div>
      </div>

      <!-- ── PRAVÝ SLOUPEC: Vizuální mockup ── -->
      <div class="relative flex justify-center lg:justify-end">

        <!-- Browser mockup karta -->
        <div class="relative w-full max-w-sm lg:max-w-none">
          <div class="bg-[#292e4c] rounded-2xl shadow-2xl overflow-hidden">

            <!-- Browser chrome -->
            <div class="bg-[#1e2338] px-4 py-3 flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-400/70"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-300/70"></span>
              <span class="w-3 h-3 rounded-full bg-green-400/70"></span>
              <div class="flex-1 bg-white/10 rounded-md mx-3 px-3 py-1 flex items-center gap-1.5">
                <svg class="w-3 h-3 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"/></svg>
                <span class="text-white/30 text-xs">vasefirma.cz</span>
              </div>
            </div>

            <!-- Fake website obsah -->
            <div class="p-5 space-y-3.5">
              <!-- Hero blok -->
              <div class="bg-[#fdc700] rounded-xl p-4 flex items-center justify-between">
                <div class="space-y-1.5">
                  <div class="bg-neutral-900/25 rounded h-3 w-28"></div>
                  <div class="bg-neutral-900/15 rounded h-2 w-20"></div>
                </div>
                <div class="bg-neutral-900/25 rounded-lg px-3 py-1.5">
                  <div class="bg-neutral-900/30 rounded h-2 w-12"></div>
                </div>
              </div>
              <!-- Tři boxy -->
              <div class="grid grid-cols-3 gap-2.5">
                <div class="bg-white/10 rounded-xl h-14"></div>
                <div class="bg-white/10 rounded-xl h-14"></div>
                <div class="bg-white/10 rounded-xl h-14"></div>
              </div>
              <!-- Textové linky -->
              <div class="space-y-2 px-1">
                <div class="bg-white/15 rounded h-2.5 w-4/5"></div>
                <div class="bg-white/10 rounded h-2 w-3/5"></div>
                <div class="bg-white/10 rounded h-2 w-2/3"></div>
              </div>
              <!-- CTA blok -->
              <div class="flex justify-center pt-1">
                <div class="bg-[#fdc700]/80 rounded-xl h-9 w-36"></div>
              </div>
              <!-- Footer bar -->
              <div class="bg-white/5 rounded-lg h-8"></div>
            </div>
          </div>

          <!-- Plovoucí badge: čas spuštění -->
          <div class="absolute -top-4 -left-4 bg-white rounded-2xl shadow-xl px-4 py-2.5 flex items-center gap-2.5 border border-neutral-100">
            <div class="w-8 h-8 bg-[#fdc700] rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-neutral-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-neutral-800 leading-tight">Spuštění za 5 dnů</p>
              <p class="text-[10px] text-neutral-500">od prvního kontaktu</p>
            </div>
          </div>

          <!-- Plovoucí badge: poptávka -->
          <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-xl px-4 py-2.5 flex items-center gap-2.5 border border-neutral-100">
            <div class="w-8 h-8 bg-[#292e4c] rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#fdc700]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-neutral-800 leading-tight">Nová poptávka</p>
              <p class="text-[10px] text-neutral-500">před 2 hodinami</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </Container>

  <!-- Yellow separator -->
  <div class="h-1 bg-[#fdc700] w-full" />
</section>
