---
import Container from '../ui/Container.astro';

const testimonials = [
  {
    text: 'Měl jsem web 4 roky, žádná poptávka. Lukáš s Standou mi ho přestavěli za týden a do měsíce přišly první kontakty z Googlu. Konečně to funguje.',
    name: 'Martin K.',
    role: 'Instalatér, Praha',
    initial: 'M',
    color: 'bg-[#292e4c]',
  },
  {
    text: 'Bál jsem se, že to bude složité a drahé. Bylo to přesně naopak – rychlé, přehledné a za rozumné peníze. A pomohli mi i s Google reklamou.',
    name: 'Jana P.',
    role: 'Kosmetická poradkyně, Brno',
    initial: 'J',
    color: 'bg-[#fdc700]',
    textColor: 'text-neutral-900',
  },
  {
    text: 'Oceňuji hlavně to, že nekomunikuji s 5 různými lidmi. Lukáš ví, co dělá na marketingu, Standa to technicky dotáhne. Jednoduché, rychlé, srozumitelné.',
    name: 'Tomáš R.',
    role: 'Truhlář na zakázku, Ostrava',
    initial: 'T',
    color: 'bg-[#292e4c]',
  },
];
---

<section class="py-16 md:py-24 bg-neutral-50" id="reference">
  <Container>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-[#fdc700] uppercase tracking-widest mb-3">Reference</p>
        <h2 class="text-3xl font-bold text-neutral-800">Co říkají lidé, kteří to zažili</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {testimonials.map((t) => (
          <div class="bg-white rounded-2xl p-6 shadow-md border border-neutral-100 flex flex-col">
            <!-- Hvězdičky -->
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-[#fdc700]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-neutral-700 mb-5 flex-1 leading-relaxed">"{t.text}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-neutral-100">
              <div class={`w-10 h-10 rounded-full ${t.color} flex items-center justify-center font-bold ${t.textColor ?? 'text-white'}`}>
                {t.initial}
              </div>
              <div>
                <div class="font-semibold text-neutral-800 text-sm">{t.name}</div>
                <div class="text-xs text-neutral-500">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
