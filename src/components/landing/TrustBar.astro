---
import Container from '../ui/Container.astro';

const stats = [
  { value: '50+', label: 'spokojených klientů' },
  { value: '10+', label: 'let v oboru' },
  { value: '5 dnů', label: 'průměrné spuštění' },
  { value: '24/7', label: 'technická správa' },
];
---

<section class="py-12 md:py-16 bg-[#fdc700]/10">
  <Container>
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-neutral-800 text-center mb-10 md:mb-14">
        Čísla, která <span class="bg-[#fdc700] px-2 py-0.5 rounded">mluví za nás</span>
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {stats.map((stat) => (
          <div class="text-center py-4 px-2 md:py-6 md:px-4 rounded-xl bg-white/90 hover:bg-white transition-colors border border-white/50 hover:border-[#fdc700]/40 shadow-sm">
            <div class="text-3xl md:text-4xl font-bold text-neutral-900 mb-1">{stat.value}</div>
            <div class="text-sm md:text-base text-neutral-600 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
