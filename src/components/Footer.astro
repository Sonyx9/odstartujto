---
import Container from './ui/Container.astro';
---

<!-- Pre-footer CTA strip -->
<div class="bg-[#fdc700] py-10 md:py-12">
  <Container>
    <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
      <div>
        <p class="text-2xl md:text-3xl font-bold text-neutral-900">Váš web může být online za 5 dní.</p>
        <p class="text-neutral-700 mt-1">Začínáme hned, jak se ozvete.</p>
      </div>
      <a href="#poptavka" class="flex-shrink-0 inline-flex items-center gap-2 bg-[#292e4c] hover:bg-neutral-900 text-white font-bold px-8 py-3.5 rounded-2xl transition-colors shadow-lg whitespace-nowrap">
        Chci nezávaznou nabídku
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </Container>
</div>

<footer class="bg-neutral-900 text-neutral-400 pt-14 pb-8">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 pb-10 border-b border-neutral-800">

      <!-- Brand -->
      <div class="md:col-span-2">
        <img src="/logo.png" alt="Odstartujto" class="h-9 w-auto mb-4 brightness-0 invert opacity-90" />
        <p class="text-neutral-500 text-sm leading-relaxed max-w-xs">
          Statické weby a Google marketing pro živnostníky a malé firmy. Rychle, férově, bez balastu.
        </p>
        <div class="flex items-center gap-2 mt-5">
          <div class="w-2 h-2 rounded-full bg-green-400"></div>
          <span class="text-sm text-neutral-500">Právě přijímáme nové projekty</span>
        </div>
      </div>

      <!-- Kontakt -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Kontakt</h4>
        <div class="space-y-2.5">
          <a href="mailto:info@odstartujto.cz" class="flex items-center gap-2 text-neutral-400 hover:text-white transition-colors text-sm">
            <svg class="w-4 h-4 text-[#fdc700]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@odstartujto.cz
          </a>
          <a href="tel:+420123456789" class="flex items-center gap-2 text-neutral-400 hover:text-white transition-colors text-sm">
            <svg class="w-4 h-4 text-[#fdc700]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            +420 123 456 789
          </a>
        </div>
      </div>

      <!-- Právní -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wide">Informace</h4>
        <div class="space-y-2.5">
          <a href="/privacy" class="block text-neutral-400 hover:text-white transition-colors text-sm">GDPR & Ochrana dat</a>
          <a href="/cookies" class="block text-neutral-400 hover:text-white transition-colors text-sm">Cookies</a>
          <a href="#faq" class="block text-neutral-400 hover:text-white transition-colors text-sm">Časté otázky</a>
        </div>
      </div>

    </div>

    <!-- Spodní bar -->
    <div class="pt-7 flex flex-col md:flex-row items-center justify-between gap-3 text-neutral-600 text-xs">
      <span>© {new Date().getFullYear()} Odstartujto. Všechna práva vyhrazena.</span>
      <span class="flex items-center gap-1.5">
        Vyrobeno s
        <svg class="w-3.5 h-3.5 text-[#fdc700]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
        v Česku
      </span>
    </div>

  </Container>
</footer>
